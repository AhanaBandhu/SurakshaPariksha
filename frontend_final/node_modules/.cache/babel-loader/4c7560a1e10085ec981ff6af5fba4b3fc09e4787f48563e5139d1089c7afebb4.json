Left, onExpire]);\n  const format = () => {\n    const h = Math.floor(timeLeft/3600), m = Math.floor((timeLeft%3600)/60), s = timeLeft%60;\n    return { h: String(h).padStart(2,'0'), m: String(m).padStart(2,'0'), s: String(s).padStart(2,'0') };\n  };\n  return { timeLeft, format, isWarning: timeLeft !== null && timeLeft <= 300 && timeLeft > 60,\n    isCritical: timeLeft !== null && timeLeft <= 60};\n}\n"],"mappings":"AAAA,OAASA,QAAQ,CAAEC,SAAS,CAAEC,MAAM,KAAQ,OAAO,CACnD,cAAe,SAAS,CAAAC,QAAQA,CAACC,cAAc,CAAEC,QAAQ,CAAE,CACzD,KAAM,CAACC,QAAQ,CAAEC,WAAW,CAAC,CAAGP,QAAQ,CAAC,IAAI,CAAC,CAC9C,KAAM,CAAAQ,UAAU,CAAGN,MAAM,CAAC,KAAK,CAAC,CAChCD,SAAS,CAAC,IAAM,CAAE,GAAIG,cAAc,GAAK,IAAI,EAAIA,cAAc,GAAKK,SAAS,CAAE,OACjEF,WAAW,CAACH,cAAc,CAAC,CAAEI,UAAU,CAACE,OAAO,CAAG,KAAK,CAAE,CAAC,CAAE,CAACN,cAAc,CAAC,CAAC,CAC3FH,SAAS,CAAC,IAAM,CACd,GAAIK,QAAQ,GAAK,IAAI,CAAE,OACvB,GAAIA,QAAQ,EAAI,CAAC,CAAE,CAAE,GAAI,CAACE,UAAU,CAACE,OAAO,EAAIL,QAAQ,CAAE,CAAEG,UAAU,CAACE,OAAO,CAAG,IAAI,CAAEL,QAAQ,CAAC,CAAC,CAAE,CAAE,OAAQ,CAC7G,KAAM,CAAAM,EAAE,CAAGC,WAAW,CAAC,IAAML,WAAW,CAAEM,CAAC,EAAKC,IAAI,CAACC,GAAG,CAAC,CAAC,CAAEF,CAAC,CAAC,CAAC,CAAC,CAAC,CAAE,IAAI,CAAC,CACxE,MAAO,IAAMG,aAAa,CAACL,EAAE,CAAC,CAChC,CAAC,CAAE,CAACL,QAAQ,CAAED,QAAQ,CAAC,CAAC,CACxB,KAAM,CAAAY,MAAM,CAAGA,CAAA,GAAM,CACnB,KAAM,CAAAC,CAAC,CAAGJ,IAAI,CAACK,KAAK,CAACb,QAAQ,CAAC,IAAI,CAAC,CAAEc,CAAC,CAAGN,IAAI,CAACK,KAAK,CAAEb,QAAQ,CAAC,IAAI,CAAE,EAAE,CAAC,CAAEe,CAAC,CAAGf,QAAQ,CAAC,EAAE,CACxF,MAAO,CAAEY,CAAC,CAAEI,MAAM,CAACJ,CAAC,CAAC,CAACK,QAAQ,CAAC,CAAC,CAAC,GAAG,CAAC,CAAEH,CAAC,CAAEE,MAAM,CAACF,CAAC,CAAC,CAACG,QAAQ,CAAC,CAAC,CAAC,GAAG,CAAC,CAAEF,CAAC,CAAEC,MAAM,CAACD,CAAC,CAAC,CAACE,QAAQ,CAAC,CAAC,CAAC,GAAG,CAAE,CAAC,CACrG,CAAC,CACD,MAAO,CAAEjB,QAAQ,CAAEW,MAAM,CAAEO,SAAS,CAAElB,QAAQ,GAAK,IAAI,EAAIA,QAAQ,EAAI,GAAG,EAAIA,QAAQ,CAAG,EAAE,CACzFmB,UAAU,CAAEnB,QAAQ,GAAK,IAAI,EAAIA,QAAQ,EAAI,EAAE,CAAC,CACpD","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}